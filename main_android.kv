<HistoryItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: "50dp"
    padding: 10
    spacing: 10
    canvas.before:
        Color:
            rgba: 0.2, 0.22, 0.28, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8]

    Label:
        id: display_label
        text: ""
        font_size: "14sp"
        text_size: self.size
        halign: "left"
        valign: "middle"
        shorten: True

    Button:
        text: "Открыть/Копия"
        size_hint_x: None
        width: "110dp"
        background_color: 0.2, 0.6, 0.4, 1
        on_press: root.action_press()

<MainScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '50dp'
            Label:
                text: "Wi-Fi Клиент"
                font_size: '24sp'
                bold: True
                halign: 'left'
                text_size: self.size

            Button:
                text: "📥 ПРИНЯТЬ (" + str(len(app.received_items)) + ")"
                size_hint_x: None
                width: '140dp'
                bold: True
                background_color: 0.9, 0.4, 0.1, 1
                on_press: root.manager.current = 'history'

        TextInput:
            id: input_field
            hint_text: "Введите текст или ссылку для отправки на ПК..."
            font_size: '18sp'
            multiline: True
            on_text: app.check_for_links(self.text)

        Button:
            id: link_button
            text: "🔗 Перейти по ссылке: " + app.detected_link
            size_hint_y: None
            height: '45dp'
            background_color: 0.1, 0.7, 0.3, 1
            opacity: 0
            disabled: True
            on_press: app.open_link()

        Label:
            id: status_label
            text: "Подключите телефон к домашнему Wi-Fi"
            font_size: '14sp'
            size_hint_y: None
            height: '30dp'
            color: 0.7, 0.7, 0.7, 1

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '50dp'
            spacing: 10
            Button:
                text: "📋 Вставить из буфера"
                background_color: 0.2, 0.5, 0.7, 1
                on_press: app.paste_from_system()
            Button:
                text: "🚀 ОТПРАВИТЬ НА ПК"
                bold: True
                background_color: 0.2, 0.7, 0.4, 1
                on_press: app.send_data()

<HistoryScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 15

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '50dp'
            Button:
                text: "⬅ Назад"
                size_hint_x: None
                width: '90dp'
                background_color: 0.4, 0.4, 0.4, 1
                on_press: root.manager.current = 'main'
            Label:
                text: "  Файлы и тексты с ноутбука"
                font_size: '20sp'
                bold: True
                halign: 'left'
                text_size: self.size

        ScrollView:
            BoxLayout:
                id: history_container
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 8
                padding: 5
