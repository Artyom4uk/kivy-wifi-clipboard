<FileItem>:
    orientation: 'vertical'
    size_hint_x: None
    width: "110dp"  # Сделали карточку чуть компактнее в ширину
    padding: 8
    spacing: 5
    canvas.before:
        Color:
            rgba: 0.15, 0.17, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [12]

    # Верхняя часть: Иконка или Картинка + Кнопка удаления
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: "45dp"
        spacing: 5

        # Контейнер для отображения (либо миниатюра, либо эмодзи-значок)
        BoxLayout:
            size_hint_x: None
            width: "45dp"
            
            # Если это картинка (icon_source не пустой)
            Image:
                source: root.icon_source
                allow_stretch: True
                keep_ratio: True
                opacity: 1 if root.icon_source else 0
                size_hint: (1, 1) if root.icon_source else (None, None)
                size: (0, 0) if not root.icon_source else self.parent.size

            # Если это документ (icon_text не пустой)
            Label:
                text: root.icon_text
                font_size: "28sp"
                opacity: 1 if root.icon_text else 0
                size_hint: (1, 1) if root.icon_text else (None, None)
                size: (0, 0) if not root.icon_text else self.parent.size

        # Маленький аккуратный крестик в углу карточки
        Button:
            text: "×"
            font_size: "16sp"
            bold: True
            size_hint: (None, None)
            size: ("20dp", "20dp")
            pos_hint: {"top": 1}
            background_normal: ""
            background_color: 0.8, 0.2, 0.2, 0.8
            on_press: root.remove_self()
            canvas.before:
                Color:
                    rgba: 0.8, 0.2, 0.2, 0.8
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]

    # Нижняя часть: Имя файла под иконкой
    Label:
        text: root.file_name
        font_size: "11sp"
        shorten: True
        shorten_from: "center"  # Обрезает середину (например: "длинное...мя.txt")
        text_size: self.size
        halign: "center"
        valign: "top"
        color: 0.9, 0.9, 0.9, 1

<ClipboardWindow>:
    orientation: 'vertical'
    padding: 20
    spacing: 15

    Label:
        text: "Wi-Fi Буфер и Файлы"
        font_size: '24sp'
        size_hint_y: None
        height: '40dp'
        bold: True

    TextInput:
        id: input_field
        hint_text: "Введите сопроводительный текст или ссылку..."
        font_size: '18sp'
        multiline: True
        on_text: root.check_for_links(self.text)

    # Увеличили высоту контейнера до 90dp, чтобы помещались вертикальные карточки
    ScrollView:
        size_hint_y: None
        height: "95dp"
        do_scroll_y: False
        do_scroll_x: True
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 0.05
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        BoxLayout:
            id: files_scroll_container
            orientation: 'horizontal'
            size_hint_x: None
            width: self.minimum_width
            padding: 8
            spacing: 10

    Button:
        id: link_button
        text: "🔗 Перейти по ссылке: " + root.detected_link
        size_hint_y: None
        height: '45dp'
        background_color: 0.1, 0.7, 0.3, 1
        opacity: 0
        disabled: True
        on_press: root.open_link()

    Label:
        id: status_label
        text: "Ожидание действий... (Ctrl+Enter для отправки)"
        font_size: '14sp'
        size_hint_y: None
        height: '30dp'
        color: 0.7, 0.7, 0.7, 1

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '50dp'
        spacing: 10

        Button:
            text: "📋 Вставить текст"
            font_size: '14sp'
            background_color: 0.2, 0.5, 0.7, 1
            on_press: root.paste_from_system()

        Button:
            text: "📁 Добавить Файлы"
            font_size: '14sp'
            background_color: 0.6, 0.4, 0.8, 1
            on_press: root.choose_file()

        Button:
            text: "🚀 ОТПРАВИТЬ"
            font_size: '14sp'
            bold: True
            background_color: 0.2, 0.7, 0.4, 1
            on_press: root.send_data()